# Auto-install missing peer dependencies during workspace installs.
auto-install-peers=true

# Link local workspace packages instead of resolving them from the registry.
link-workspace-packages=true

# Prefer local workspace packages when a matching version exists.
prefer-workspace-packages=true

# Keep a single lockfile at the repository root for the whole monorepo.
shared-workspace-lockfile=true

# Save internal workspace dependencies using the workspace protocol.
save-workspace-protocol=rolling

# Reject packages published in the last 7 days to reduce supply-chain risk.
min-release-age=7

# Block dependency lifecycle scripts during install; run trusted scripts manually.
ignore-scripts=true